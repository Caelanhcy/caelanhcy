  <script>
    const modal = document.getElementById('export-modal');
    const triggers = document.querySelectorAll('[data-export-trigger]');
    const closers = modal?.querySelectorAll('[data-export-close]');

    function openModal() {
      if (!modal) return;
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('export-modal-open');
    }
    function closeModal() {
      if (!modal) return;
      modal.hidden = true;
      modal.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('export-modal-open');
    }

    triggers?.forEach((b) => b.addEventListener('click', openModal));
    closers?.forEach((b) => b.addEventListener('click', closeModal));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    // 测试入口：通过 URL 参数触发打印模式（用于无头 Chrome PDF 生成）
    (function applyURLPrint() {
      const params = new URLSearchParams(window.location.search);
      if (!params.get('autoprint')) return;
      const root = document.documentElement;
      root.classList.add('print-mode');
      if (params.get('depth') === 'in-depth') root.classList.add('print-in-depth');
      if (params.get('theme') === 'light') root.classList.add('print-light');
      (params.get('hide') || '').split(',').forEach((tok) => {
        const t = tok.trim();
        if (t === 'contact') root.classList.add('print-hide-contact');
        else if (t.startsWith('role:')) {
          const role = t.slice(5);
          document.querySelectorAll(`[data-role="${role}"]`).forEach((el) => el.classList.add('print-hide-role'));
        }
      });
    })();

    const goBtn = modal?.querySelector('[data-export-go]');
    goBtn?.addEventListener('click', () => {
      const root = document.documentElement;
      const depthEl = modal!.querySelector<HTMLInputElement>('input[name="export-depth"]:checked');
      const themeEl = modal!.querySelector<HTMLInputElement>('input[name="export-theme"]:checked');
      const contactEl = modal!.querySelector<HTMLInputElement>('input[name="export-contact"]');

      const depth = depthEl?.value || 'simplified';
      const theme = themeEl?.value || 'dark';
      const includeContact = !!contactEl?.checked;

      root.classList.add('print-mode');
      root.classList.toggle('print-in-depth', depth === 'in-depth');
      root.classList.toggle('print-light', theme === 'light');
      root.classList.toggle('print-hide-contact', !includeContact);
      /* 肖像始终包含 —— 表单中不再提供这个选项 */

      const roles = modal!.querySelectorAll<HTMLInputElement>('input[name="export-role"]');
      roles.forEach((r) => {
        const sel = `[data-role="${r.value}"]`;
        document.querySelectorAll<HTMLElement>(sel).forEach((el) => {
          el.classList.toggle('print-hide-role', !r.checked);
        });
      });

      closeModal();
      setTimeout(() => { window.print(); cleanup(); }, 80);

      function cleanup() {
        setTimeout(() => {
          root.classList.remove('print-mode', 'print-in-depth', 'print-light', 'print-hide-contact');
          document.querySelectorAll('.print-hide-role').forEach((el) => el.classList.remove('print-hide-role'));
        }, 600);
      }
    });
  </script>
