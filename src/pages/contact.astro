---
import Base from '../layouts/Base.astro';

// Formspree endpoint — replace before deploy.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/REPLACE_ME';
---
<Base
  title="contact — caelan h.c.y"
  description="A short qualifying form. Restrained, factual."
  active="contact"
>
  <article class="contact-page">

    <form
      id="contact-form"
      method="POST"
      action={FORMSPREE_ENDPOINT}
    >

      {/* Module 1 — identity card + category strip ------------------- */}
      <div class="grid-12">
        <section class="tile contact-id-tile">
          <figure class="portrait-card portrait-card--small" style="margin:0;">
            <div class="portrait-frame">
              <img src="/portrait/portrait-small.jpg" alt="Caelan H.C.Y" width="96" height="120" loading="eager" />
              <span class="corner corner--tl" aria-hidden="true"></span>
              <span class="corner corner--tr" aria-hidden="true"></span>
              <span class="corner corner--bl" aria-hidden="true"></span>
              <span class="corner corner--br" aria-hidden="true"></span>
            </div>
          </figure>
          <div class="id-text">
            <p style="margin-bottom: var(--space-1);">[ inbound / qualifying form ]</p>
            <h1>contact</h1>
            <p style="margin-top: var(--space-1);">recipient · caelan h.c.y</p>
          </div>
        </section>

        <section class="tile category-strip">
          <div class="tile-id">
            <span class="id-num">01</span>
            <span>category</span>
            <span class="id-rule"></span>
            <span>select one</span>
          </div>
          <span class="field-label">reason for reaching out</span>
          <div class="chip-row" role="radiogroup" aria-label="Reason">
            <label>
              <span class="chip-num">01</span>
              <input type="radio" name="category" value="Hiring" required />
              <span>hiring</span>
            </label>
            <label>
              <span class="chip-num">02</span>
              <input type="radio" name="category" value="Advisory / Board" />
              <span>advisory / board</span>
            </label>
            <label>
              <span class="chip-num">03</span>
              <input type="radio" name="category" value="Press / Media" />
              <span>press / media</span>
            </label>
            <label>
              <span class="chip-num">04</span>
              <input type="radio" name="category" value="Speaking" />
              <span>speaking</span>
            </label>
            <label>
              <span class="chip-num">05</span>
              <input type="radio" name="category" value="Other" />
              <span>other</span>
            </label>
          </div>
        </section>
      </div>

      {/* Module 2 — field grid (62/38 inside the tile) -------------- */}
      <div class="grid-12">
        <section class="tile field-grid-tile">
          <div class="tile-id">
            <span class="id-num">02</span>
            <span>fields</span>
            <span class="id-rule"></span>
            <span>branch + universal</span>
          </div>

          <div class="tile-grid-phi">
            {/* Left 62% — branch-specific */}
            <div class="sub-tile branch-tile">
              <h4>[ branch ]</h4>

              <div class="branches-wrap">
                <div class="branch" data-branch="Hiring" hidden>
                  <div class="field">
                    <label for="hire-company">company</label>
                    <input id="hire-company" type="text" name="hiring_company" autocomplete="organization" />
                  </div>
                  <div class="field">
                    <label for="hire-role">role title</label>
                    <input id="hire-role" type="text" name="hiring_role" />
                  </div>
                  <div class="field">
                    <label for="hire-base">base salary range</label>
                    <input id="hire-base" type="text" name="hiring_base" placeholder="e.g. usd 220–280k" />
                  </div>
                  <div class="field">
                    <label for="hire-location">location / remote</label>
                    <input id="hire-location" type="text" name="hiring_location" />
                  </div>
                  <div class="field">
                    <label for="hire-desc">brief description</label>
                    <textarea id="hire-desc" name="hiring_description" rows="4"></textarea>
                  </div>
                </div>

                <div class="branch" data-branch="Advisory / Board" hidden>
                  <div class="field">
                    <label for="adv-company">company</label>
                    <input id="adv-company" type="text" name="advisory_company" />
                  </div>
                  <div class="field">
                    <label for="adv-stage">stage</label>
                    <input id="adv-stage" type="text" name="advisory_stage" placeholder="seed / series a / growth" />
                  </div>
                  <div class="field">
                    <label for="adv-commit">time commitment expected</label>
                    <input id="adv-commit" type="text" name="advisory_commitment" placeholder="e.g. 4 hrs / month" />
                  </div>
                  <div class="field">
                    <label for="adv-desc">brief description</label>
                    <textarea id="adv-desc" name="advisory_description" rows="4"></textarea>
                  </div>
                </div>

                <div class="branch" data-branch="Press / Media" hidden>
                  <div class="field">
                    <label for="press-pub">publication</label>
                    <input id="press-pub" type="text" name="press_publication" />
                  </div>
                  <div class="field">
                    <label for="press-deadline">deadline</label>
                    <input id="press-deadline" type="text" name="press_deadline" />
                  </div>
                  <div class="field">
                    <label for="press-angle">angle</label>
                    <input id="press-angle" type="text" name="press_angle" />
                  </div>
                  <div class="field">
                    <label for="press-desc">brief description</label>
                    <textarea id="press-desc" name="press_description" rows="4"></textarea>
                  </div>
                </div>

                <div class="branch" data-branch="Speaking" hidden>
                  <div class="field">
                    <label for="spk-event">event name</label>
                    <input id="spk-event" type="text" name="speaking_event" />
                  </div>
                  <div class="field">
                    <label for="spk-date">date</label>
                    <input id="spk-date" type="text" name="speaking_date" />
                  </div>
                  <div class="field">
                    <label for="spk-audience">audience description</label>
                    <input id="spk-audience" type="text" name="speaking_audience" />
                  </div>
                  <div class="field">
                    <label for="spk-format">format</label>
                    <input id="spk-format" type="text" name="speaking_format" placeholder="panel / keynote / workshop" />
                  </div>
                  <div class="field">
                    <label for="spk-hono">honorarium range</label>
                    <input id="spk-hono" type="text" name="speaking_honorarium" />
                  </div>
                </div>

                <div class="branch" data-branch="Other" hidden>
                  <div class="field">
                    <label for="other-desc">message</label>
                    <textarea id="other-desc" name="other_description" rows="6"></textarea>
                  </div>
                </div>

                <p id="branch-empty" style="font-family: var(--mono); font-size: var(--t-xs); letter-spacing: 0.06em; color: var(--ink-3);">
                  select a category above to reveal branch-specific fields.
                </p>
              </div>
            </div>

            {/* Right 38% — universal */}
            <div class="sub-tile universal-tile">
              <h4>[ universal ]</h4>
              <div class="branch" style="display:grid; gap: var(--space-3);">
                <div class="field">
                  <label for="name">your name</label>
                  <input id="name" type="text" name="name" autocomplete="name" required />
                </div>

                <div class="field">
                  <label for="email">email</label>
                  <input id="email" type="email" name="email" autocomplete="email" required />
                </div>

                <div class="field">
                  <label for="referrer">how did you find me? <span class="muted">(optional)</span></label>
                  <input id="referrer" type="text" name="referrer" />
                </div>
              </div>
            </div>
          </div>

          {/* Honeypot */}
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        </section>
      </div>

      {/* Module 3 — submit band ------------------------------------- */}
      <div class="grid-12">
        <div class="submit-band">
          <button class="submit-btn" type="submit">[ send ]</button>
          <div class="submit-status">
            <span class="ready">[ ready ]</span> &nbsp; replies are restrained and factual.
            &nbsp;·&nbsp; direct line: <a href="mailto:chuanyichuanyi@gmail.com" style="border-bottom: 1px solid var(--rule-soft); color: inherit;">chuanyichuanyi@gmail.com</a>
          </div>
        </div>
      </div>

    </form>

    <div class="grid-12" id="thanks-wrap" hidden>
      <div class="thanks">
        <p>thank you. received. a reply will follow — measured, on its own cadence.</p>
      </div>
    </div>

  </article>

  <script>
    // Branch toggling
    const radios = document.querySelectorAll<HTMLInputElement>('input[name="category"]');
    const branches = document.querySelectorAll<HTMLElement>('.branch[data-branch]');
    const branchEmpty = document.getElementById('branch-empty');

    function showBranch(value: string) {
      let any = false;
      branches.forEach((b) => {
        const match = b.getAttribute('data-branch') === value;
        b.hidden = !match;
        if (match) any = true;
      });
      if (branchEmpty) branchEmpty.hidden = any;
    }

    radios.forEach((r) => {
      r.addEventListener('change', () => {
        if (r.checked) showBranch(r.value);
      });
    });

    // Form submit
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const thanksWrap = document.getElementById('thanks-wrap');

    form?.addEventListener('submit', async (e) => {
      const action = form.getAttribute('action') || '';
      if (action.includes('REPLACE_ME')) {
        e.preventDefault();
        console.warn('Formspree endpoint not configured. Update src/pages/contact.astro before deploy.');
        form.hidden = true;
        if (thanksWrap) thanksWrap.hidden = false;
        return;
      }

      e.preventDefault();
      const data = new FormData(form);
      try {
        const res = await fetch(action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.hidden = true;
          if (thanksWrap) thanksWrap.hidden = false;
        } else {
          alert('Something went wrong. Please email directly: chuanyichuanyi@gmail.com');
        }
      } catch {
        alert('Network error. Please email directly: chuanyichuanyi@gmail.com');
      }
    });
  </script>
</Base>
